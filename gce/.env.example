# Compute Engine Deployment — Environment Variables
# Copy this file to gce/.env and fill in your values.
#
# VM Region: asia-south1 (Mumbai, India) for lowest latency to Indian users.
# Vertex AI Location: us-central1 (Gemini Live model is only available here).

GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
DEMO_AGENT_MODEL=gemini-live-2.5-flash-native-audio
CROP_DIR=./crop
DISEASE_DIR=./diseases

# Conversation recording (leave empty to disable)
GCS_CONVERSATION_BUCKET=kisan-mitra-conversations
RECORD_AUDIO=true

# GCE-specific settings (used by gce/deploy.sh)
GCE_ZONE=asia-south1-b
GCE_INSTANCE_NAME=kisan-mitra-vm
GCE_MACHINE_TYPE=e2-medium

# Optional: set this to clone from git instead of copying local files
# GIT_REPO_URL=https://github.com/your-org/kisan-mitra.git
