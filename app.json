{
  "name": "Kisan Mitra",
  "description": "AI-powered agricultural assistant for Indian oilseed farmers using Gemini Live API",
  "options": {
    "allow-unauthenticated": true,
    "memory": "512Mi",
    "cpu": "1",
    "timeout": "600",
    "concurrency": "80",
    "max-instances": "10",
    "min-instances": "0"
  },
  "env": {
    "GOOGLE_GENAI_USE_VERTEXAI": {
      "description": "Use Vertex AI backend",
      "value": "TRUE"
    },
    "CROP_DIR": {
      "description": "Path to crop knowledge base",
      "value": "./crop"
    },
    "DISEASE_DIR": {
      "description": "Path to disease knowledge base",
      "value": "./diseases"
    },
    "KNOWLEDGE_MODEL": {
      "description": "Model for knowledge agent",
      "value": "gemini-2.5-flash"
    },
    "VISION_MODEL": {
      "description": "Model for vision agent",
      "value": "gemini-2.5-flash"
    }
  },
  "hooks": {
    "prebuild": {
      "commands": [
        "gcloud services enable aiplatform.googleapis.com run.googleapis.com cloudbuild.googleapis.com --project $GOOGLE_CLOUD_PROJECT",
        "echo 'Waiting for APIs to initialize...'",
        "sleep 30",
        "gcloud projects add-iam-policy-binding $GOOGLE_CLOUD_PROJECT --member=serviceAccount:$(gcloud projects describe $GOOGLE_CLOUD_PROJECT --format='value(projectNumber)')-compute@developer.gserviceaccount.com --role=roles/aiplatform.user"
      ]
    }
  }
}
